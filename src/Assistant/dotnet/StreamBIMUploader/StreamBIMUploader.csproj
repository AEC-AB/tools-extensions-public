<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <ExtensionId>StreamBIMUploader</ExtensionId>
    <Version>1.0.0</Version>
    <Title>StreamBIM File Uploader</Title>
    <Description>Upload files from a local folder to StreamBIM.</Description>
    <PackageTags>StreamBIM;Upload;Assistant;Extension;AssistantExtension</PackageTags>
    <PackageIcon>Icon.png</PackageIcon>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="FluentFTP" Version="48.0.1" />
    <PackageReference Include="Meziantou.Framework.Win32.CredentialManager" Version="1.7.3" />
  </ItemGroup>
  <ItemGroup>
    <None Include="Icon.png" Pack="true" PackagePath="" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\StreamBim\**\*.cs" LinkBase="Shared" />
  </ItemGroup>
</Project>