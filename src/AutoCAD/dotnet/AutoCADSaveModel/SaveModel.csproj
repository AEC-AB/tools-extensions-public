<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ExtensionId>SaveModel</ExtensionId>
    <Version>0.0.4</Version>
    <Title>Save AutoCAD File</Title>
    <Description>Save your AutoCAD file</Description>
    <PackageTags>AutoCAD;Assistant;Extension</PackageTags>
    <PackageIcon>Icon.png</PackageIcon>
    <!-- 
		Adjust MainAutoCADVersion to get IntelliSense for the correct version do a 
		dotnet restore to restore the correct nuget packages for the selected AutoCAD version.
		-->
		<MainAutoCADVersion Condition="'$(Configuration)' == 'Debug'">2024</MainAutoCADVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CSharp" Version="4.7.0" />
  </ItemGroup>
  <ItemGroup>
    <None Include="Icon.png" Pack="true" PackagePath="" />
  </ItemGroup>

</Project>
